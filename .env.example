# App
APP_NAME=fastapi-clean
DEBUG=false
API_PREFIX=/api/v1

# PostgreSQL (TimescaleDB + PGVector)
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app

# JWT
SECRET_KEY=change-me-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Redis (cache + ARQ)
REDIS_URL=redis://localhost:6379/0

# Observability
LOG_LEVEL=INFO
METRICS_ENABLED=true

# Embeddings (PUT .../embedding + search/semantic/text)
# dummy = vetor fixo por texto (stdlib, só testar upsert/PGVector). Sem custo.
# local = Sentence-Transformers (pip install -e ".[local-embeddings]").
# openai / gemini = APIs (defina a chave correspondente).
EMBEDDING_PROVIDER=dummy
# LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
#
# Se EMBEDDING_PROVIDER=openai:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
#
# Se EMBEDDING_PROVIDER=gemini ou POST .../suggestions/description:
# (SDK Python: google-genai — pip já inclui no projeto)
# GEMINI_API_KEY=
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Modelo de texto (estável: gemini-2.5-flash; mais barato: gemini-2.5-flash-lite)
# GEMINI_TEXT_MODEL=gemini-2.5-flash
